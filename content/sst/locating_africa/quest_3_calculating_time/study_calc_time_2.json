    {
      "tabTitle": "GMT ➡ East",
      "title": "Method 1: GMT to East",
      "description": "Example: It is 12:00 PM at Greenwich. What time is it in Uganda (45°E)?",
      "initialRotation": [-25, -5, 0],
      "zoomFactor": 1.4,

      "lines": [
        { "type": "lon", "value": 0, "color": "#3b82f6", "label": "GMT (12:00)" },
        { "type": "lon", "value": 45, "color": "#facc15", "label": "Uganda (?)" }
      ],
      "connection": { "from": [0, 51.5], "to": [45, 1] },
      "markers": [
          { "label": "Greenwich", "lat": 51.5, "lon": 0, "color": "#3b82f6" },
          { "label": "Kampala", "lat": 1, "lon": 45, "color": "#ef4444" }
      ],

      "steps": [
        "<b>Step 1 (Difference):</b> Find the difference in degrees. <br/>45° - 0° = <b>45°</b>.",
        "<b>Step 2 (Convert):</b> Divide degrees by 15. <br/>45 ÷ 15 = <b>3 Hours</b>.",
        "<b>Step 3 (Decide):</b> Uganda is EAST of Greenwich. East is Ahead, so we <b>ADD</b>.",
        "<b>Step 4 (Final):</b> 12:00 PM + 3 hours = <b>3:00 PM</b>."
      ]
    },
